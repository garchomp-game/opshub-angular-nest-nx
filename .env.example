# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opshub?schema=public"

# ─── JWT (MUST change in production!) ───
JWT_SECRET="CHANGE_ME"
JWT_REFRESH_SECRET="CHANGE_ME"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───
PORT=3000
CORS_ORIGIN="http://localhost:4200"
NODE_ENV="development"

# ─── Mail (MailHog for development) ───
SMTP_HOST="localhost"
SMTP_PORT=1025
MAIL_FROM="noreply@opshub.local"
APP_URL="http://localhost:4200"

# ─── Redis ───
REDIS_HOST="localhost"
REDIS_PORT=6379

# ─── Cluster mode (Node.js only; disabled for Bun — use PM2 instead) ───
CLUSTER_ENABLED="false"
CLUSTER_WORKERS=4
